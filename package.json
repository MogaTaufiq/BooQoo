    "autoprefixer": "^10.4.16",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "classnames": "^2.3.2",
    "date-fns": "^2.30.0",
    "idb": "^7.1.1",
    "next": "^14.1.0",
    "next-auth": "^4.24.14",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
