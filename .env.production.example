# ============================================
# Production Environment Variables Template
# Copy this file to .env.production and fill in the values
# ============================================

# Database Configuration
POSTGRES_USER=booqoo
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=booqoo_production
DATABASE_URL=postgresql://booqoo:your-secure-password-here@postgres:5432/booqoo_production?schema=public

# NextAuth Configuration
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://booqoo.yourdomain.com

# Application Configuration
NODE_ENV=production
PORT=3000
APP_URL=https://booqoo.yourdomain.com

# Optional: Error Monitoring (Sentry)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Optional: Analytics
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Docker Registry (for CI/CD)
DOCKER_USERNAME=your-dockerhub-username
