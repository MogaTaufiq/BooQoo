// ============================================
// BooQoo Prisma Schema
// PostgreSQL Multi-Tenant Architecture
// ============================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User & Authentication
// ============================================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  phone        String?
  storeId      String    @map("store_id")
  role         UserRole  @default(OWNER)
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  stockMovements StockMovement[]

  @@index([storeId])
  @@index([email])
  @@map("users")
}

enum UserRole {
  OWNER
  CASHIER
  VIEWER
}

// ============================================
// Store (Tenant)
// ============================================

model Store {
  id          String    @id @default(uuid())
  name        String
  ownerId     String    @map("owner_id")
  description String?
  phone       String?
  address     String?
  timezone    String    @default("Asia/Jakarta")
  currency    Currency  @default(IDR)
  settings    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  users         User[]
  products      Product[]
  inventoryItems InventoryItem[]
  transactions  Transaction[]
  stockMovements StockMovement[]

  @@index([ownerId])
  @@map("stores")
}

enum Currency {
  IDR
  USD
}

// ============================================
// Products & Variants
// ============================================

model Product {
  id          String      @id @default(uuid())
  storeId     String      @map("store_id")
  name        String
  sku         String      @unique
  description String?
  category    String?
  unit        ProductUnit @default(PCS)
  priceSell   Decimal     @map("price_sell") @db.Decimal(10, 2)
  priceCost   Decimal?    @map("price_cost") @db.Decimal(10, 2)
  imageUrl    String?     @map("image_url")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  store            Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants         ProductVariant[]
  inventoryItems   InventoryItem[]
  transactionDetails TransactionDetail[]
  stockMovements   StockMovement[]

  @@index([storeId])
  @@index([sku])
  @@index([storeId, category])
  @@index([storeId, isActive])
  @@map("products")
}

enum ProductUnit {
  PCS
  KG
  GRAM
  LITER
  ML
  BOX
  PACK
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String   @map("product_id")
  name          String
  skuSuffix     String   @map("sku_suffix")
  priceModifier Decimal  @default(0) @map("price_modifier") @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItems     InventoryItem[]
  transactionDetails TransactionDetail[]

  @@index([productId])
  @@map("product_variants")
}

// ============================================
// Inventory Management
// ============================================

model InventoryItem {
  id            String    @id @default(uuid())
  storeId       String    @map("store_id")
  productId     String    @map("product_id")
  variantId     String?   @map("variant_id")
  quantity      Int       @default(0)
  batchCode     String?   @map("batch_code")
  expiryDate    DateTime? @map("expiry_date")
  costPrice     Decimal?  @map("cost_price") @db.Decimal(10, 2)
  lastCountedAt DateTime? @map("last_counted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  store   Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([productId])
  @@index([storeId, productId, variantId])
  @@index([batchCode])
  @@index([expiryDate])
  @@map("inventory_items")
}

model StockMovement {
  id          String            @id @default(uuid())
  storeId     String            @map("store_id")
  productId   String            @map("product_id")
  variantId   String?           @map("variant_id")
  type        StockMovementType
  quantity    Int
  batchCode   String?           @map("batch_code")
  reason      String?
  referenceId String?           @map("reference_id")
  performedBy String            @map("performed_by")
  createdAt   DateTime          @default(now()) @map("created_at")

  // Relations
  store       Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  performedByUser User @relation(fields: [performedBy], references: [id])

  @@index([storeId])
  @@index([productId])
  @@index([storeId, createdAt])
  @@index([referenceId])
  @@map("stock_movements")
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  SALE
  RETURN
}

// ============================================
// Transactions (POS)
// ============================================

model Transaction {
  id                String        @id @default(uuid())
  storeId           String        @map("store_id")
  transactionDate   DateTime      @map("transaction_date")
  totalAmount       Decimal       @map("total_amount") @db.Decimal(10, 2)
  paymentMethod     PaymentMethod @map("payment_method")
  paymentReference  String?       @map("payment_reference")
  amountReceived    Decimal?      @map("amount_received") @db.Decimal(10, 2)
  changeAmount      Decimal?      @map("change_amount") @db.Decimal(10, 2)
  notes             String?
  createdBy         String        @map("created_by")
  syncStatus        SyncStatus    @default(SYNCED) @map("sync_status")
  createdAtLocal    DateTime      @map("created_at_local")
  createdAtServer   DateTime      @default(now()) @map("created_at_server")
  conflictFlag      Boolean       @default(false) @map("conflict_flag")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  store   Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdByUser User          @relation(fields: [createdBy], references: [id])
  items   TransactionDetail[]

  @@index([storeId])
  @@index([storeId, transactionDate])
  @@index([syncStatus])
  @@index([createdBy])
  @@map("transactions")
}

enum PaymentMethod {
  CASH
  TRANSFER_BCA
  TRANSFER_BRI
  TRANSFER_MANDIRI
  TRANSFER_BNI
  EWALLET_OVO
  EWALLET_GOPAY
  EWALLET_DANA
  EWALLET_SHOPEEPAY
}

enum SyncStatus {
  PENDING
  SYNCING
  SYNCED
  CONFLICT
  FAILED
}

model TransactionDetail {
  id             String   @id @default(uuid())
  transactionId  String   @map("transaction_id")
  productId      String   @map("product_id")
  productName    String   @map("product_name")
  variantId      String?  @map("variant_id")
  variantName    String?  @map("variant_name")
  quantity       Int
  priceUnit      Decimal  @map("price_unit") @db.Decimal(10, 2)
  subtotal       Decimal  @db.Decimal(10, 2)
  batchCodeUsed  String?  @map("batch_code_used")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  transaction Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([productId])
  @@map("transaction_details")
}
